# ── Database ──────────────────────────────────────────────────
# Default to PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/watchqueue

# ── Authentication ────────────────────────────────────────────
# Generate a secure key using: `openssl rand -hex 32`
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Groq AI (for auto-categorization) ─
# Get a free key from https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ── GitHub Models AI (for timetable extraction) ─
# Get a free Personal Access Token from GitHub Settings > Developer Settings
GITHUB_TOKEN=your-github-token-here
